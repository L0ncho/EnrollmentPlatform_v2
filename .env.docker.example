# Copia a .env en EC2 (no commitear). Mismas variables que run-prod.sh / application-prod.properties
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:oracle:thin:@enrollmentplatformdb_high
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
ORACLE_WALLET_DIR=/app/wallet
SERVER_PORT=8080

# AWS S3 — producción (sin AWS_S3_ENDPOINT; el SDK usa el endpoint regional)
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Seguridad JWT Azure AD (requerido en producción)
ENROLLMENT_SECURITY_JWT_ENABLED=true
AZURE_B2C_JWK_SET_URI=https://login.microsoftonline.com/enrollmentplatform.onmicrosoft.com/discovery/v2.0/keys
AZURE_B2C_AUDIENCE=21bae56f-a579-4687-a0e8-b1f341d8d881
# ENROLLMENT_SECURITY_LOG_LEVEL=INFO

# Opcional si usas imagen de Docker Hub en lugar de build local:
# DOCKERHUB_USERNAME=tu_usuario
